<style>
:root{--gold-soft:#f4c430;}
.hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:130px 28px 90px;position:relative;z-index:1;overflow:hidden;}
.orb{position:absolute;border-radius:50%;pointer-events:none;filter:blur(90px);will-change:transform;}
.orb-1{width:700px;height:700px;background:radial-gradient(circle,rgba(255,77,109,.22),transparent 70%);top:-180px;left:-220px;animation:orbf 9s ease-in-out infinite;}
.orb-2{width:550px;height:550px;background:radial-gradient(circle,rgba(157,78,221,.26),transparent 70%);bottom:-120px;right:-170px;animation:orbf 11s ease-in-out infinite reverse;}
.orb-3{width:350px;height:350px;background:radial-gradient(circle,rgba(255,215,0,.12),transparent 70%);top:50%;left:50%;animation:orbf3 7s ease-in-out infinite 1.5s;}
@keyframes orbf{0%,100%{transform:translateY(0) scale(1);}50%{transform:translateY(-35px) scale(1.04);}}
@keyframes orbf3{0%,100%{transform:translate(-50%,-50%) scale(1);}50%{transform:translate(-50%,-55%) scale(1.06);}}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--surface-2);border:1px solid var(--border);padding:8px 18px;border-radius:50px;font-size:.76rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--violet-light);margin-bottom:30px;animation:fadeInDown .7s ease both;}
.pulse-dot{width:8px;height:8px;background:var(--rose);border-radius:50%;animation:pdot 1.6s ease infinite;}
@keyframes pdot{0%,100%{box-shadow:0 0 0 0 rgba(255,77,109,.6);}50%{box-shadow:0 0 0 8px rgba(255,77,109,0);}}
@keyframes fadeInDown{from{opacity:0;transform:translateY(-18px);}to{opacity:1;transform:translateY(0);}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(26px);}to{opacity:1;transform:translateY(0);}}
.hero-h1{font-family:var(--font-display);font-size:clamp(3rem,7.5vw,6.8rem);font-weight:900;line-height:1.06;letter-spacing:-1.5px;margin-bottom:24px;animation:fadeInUp .85s ease .15s both;}
.hero-h1 .line-plain{display:block;color:var(--text);}
.hero-h1 .line-grad{display:block;background:linear-gradient(135deg,var(--rose) 0%,var(--gold-soft) 45%,var(--violet-light) 90%);background-size:200% 200%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:gshift 5s ease infinite;}
@keyframes gshift{0%,100%{background-position:0% 50%;}50%{background-position:100% 50%;}}
.hero-h1 .line-italic{display:block;font-style:italic;color:var(--text);opacity:.9;}
.hero-sub{font-family:var(--font-accent);font-style:italic;font-size:clamp(1rem,2vw,1.3rem);color:var(--text-2);max-width:620px;margin:0 auto 42px;line-height:1.85;font-weight:300;animation:fadeInUp .85s ease .3s both;}
.hero-cta{display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;margin-bottom:56px;animation:fadeInUp .85s ease .45s both;}
.dl-pill{display:inline-flex;align-items:center;gap:11px;padding:14px 26px;border-radius:16px;border:1.5px solid var(--border);background:var(--surface-2);color:var(--text);text-decoration:none;transition:var(--transition);}
.dl-pill:hover{border-color:var(--rose);background:rgba(255,77,109,.1);transform:translateY(-3px);box-shadow:var(--shadow-rose);}
.dl-pill-icon{font-size:1.8rem;line-height:1;}
.dl-pill-small{font-size:.68rem;color:var(--text-3);display:block;}
.dl-pill-big{font-size:.98rem;font-weight:700;display:block;}
.hero-stats{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;animation:fadeInUp .85s ease .6s both;}
.stat-pill{text-align:center;padding:0 32px;position:relative;}
.stat-pill+.stat-pill::before{content:'';position:absolute;left:0;top:10%;bottom:10%;width:1px;background:var(--border);}
.stat-n{font-family:var(--font-display);font-size:1.9rem;font-weight:900;background:linear-gradient(135deg,var(--rose),var(--gold-soft));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;display:block;line-height:1;}
.stat-l{font-size:.72rem;color:var(--text-3);text-transform:uppercase;letter-spacing:1px;margin-top:5px;display:block;}
.floating-cards{position:absolute;inset:0;pointer-events:none;}
.fc{position:absolute;background:var(--card-bg);border:1px solid var(--border);border-radius:16px;padding:11px 16px;display:flex;align-items:center;gap:10px;backdrop-filter:blur(14px);box-shadow:var(--shadow-violet);animation:fcfloat var(--fd,6s) ease-in-out infinite var(--fdl,0s);max-width:220px;}
@keyframes fcfloat{0%,100%{transform:translateY(0) rotate(var(--fr,-2deg));}50%{transform:translateY(-12px) rotate(calc(var(--fr,-2deg)*-1));}}
.fc-1{top:22%;left:2%;--fd:7s;--fdl:0s;--fr:-3deg;}
.fc-2{top:60%;left:1%;--fd:5.5s;--fdl:.8s;--fr:2deg;}
.fc-3{top:18%;right:2%;--fd:6.5s;--fdl:.4s;--fr:3deg;}
.fc-4{top:62%;right:1%;--fd:8s;--fdl:1.2s;--fr:-2deg;}
.fc-ava{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--rose),var(--violet-mid));display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;}
.fc-main{font-size:.8rem;font-weight:600;color:var(--text);line-height:1.2;}
.fc-sub{font-size:.7rem;color:var(--text-3);margin-top:2px;}
.trust-bar{background:var(--surface-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:18px 0;}
.trust-inner{display:flex;align-items:center;justify-content:center;gap:32px;flex-wrap:wrap;}
.trust-item{display:flex;align-items:center;gap:7px;font-size:.8rem;color:var(--text-3);font-weight:500;}
.hiw-bg{background:linear-gradient(180deg,transparent,var(--bg-2) 20%,var(--bg-2) 80%,transparent);}
.steps-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:22px;margin-top:58px;}
.step-card{background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius);padding:34px 22px 28px;text-align:center;position:relative;overflow:hidden;transition:var(--transition);backdrop-filter:blur(12px);}
.step-card:hover{transform:translateY(-6px);border-color:rgba(255,77,109,.3);}
.step-num{position:absolute;top:10px;right:14px;font-family:var(--font-display);font-size:3.5rem;font-weight:900;color:var(--border);line-height:1;}
.step-icon{width:58px;height:58px;border-radius:18px;background:linear-gradient(135deg,var(--rose),var(--violet-mid));display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin:0 auto 16px;box-shadow:var(--shadow-rose);}
.step-card h3{font-family:var(--font-display);font-size:1.1rem;font-weight:700;color:var(--text);margin-bottom:9px;}
.step-card p{font-size:.84rem;color:var(--text-3);line-height:1.75;}
.cosmic-grid{display:grid;grid-template-columns:1fr 1fr;gap:68px;align-items:center;}
.cosmic-features{display:flex;flex-direction:column;gap:16px;margin-top:30px;}
.cf-row{display:flex;gap:15px;align-items:flex-start;padding:16px 18px;background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius-sm);transition:var(--transition);backdrop-filter:blur(10px);}
.cf-row:hover{border-color:var(--border-hover);transform:translateX(5px);}
.cf-icon{font-size:1.6rem;flex-shrink:0;width:42px;height:42px;display:flex;align-items:center;justify-content:center;}
.cf-title{font-family:var(--font-display);font-size:.94rem;font-weight:700;color:var(--text);margin-bottom:4px;}
.cf-desc{font-size:.82rem;color:var(--text-3);line-height:1.6;}
.zodiac-visual{position:relative;height:460px;display:flex;align-items:center;justify-content:center;}
.z-ring{border-radius:50%;position:absolute;display:flex;align-items:center;justify-content:center;border:1.5px solid var(--border);}
.z-outer{width:310px;height:310px;animation:zspin 50s linear infinite;}
.z-mid{width:195px;height:195px;border-style:dashed;animation:zspin 35s linear infinite reverse;}
@keyframes zspin{from{transform:rotate(0);}to{transform:rotate(360deg);}}
.z-core{width:86px;height:86px;border-radius:50%;background:linear-gradient(135deg,var(--rose),var(--violet-mid));display:flex;align-items:center;justify-content:center;font-size:2rem;box-shadow:0 0 50px rgba(255,77,109,.55),0 0 90px rgba(157,78,221,.3);animation:cpulse 3s ease-in-out infinite;position:relative;z-index:2;}
@keyframes cpulse{0%,100%{box-shadow:0 0 50px rgba(255,77,109,.5),0 0 90px rgba(157,78,221,.25);}50%{box-shadow:0 0 80px rgba(255,77,109,.8),0 0 130px rgba(157,78,221,.5);}}
.zsign{position:absolute;font-size:1.2rem;width:26px;height:26px;display:flex;align-items:center;justify-content:center;}
.profiles-section{background:var(--bg-2);}
.profiles-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:58px;}
.profile-card{background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:var(--transition);backdrop-filter:blur(12px);cursor:pointer;}
.profile-card:hover{transform:translateY(-7px);box-shadow:var(--shadow-violet);}
.profile-img-wrap{position:relative;height:280px;overflow:hidden;background:var(--bg-3);}
.profile-img-fallback{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:5rem;z-index:0;}
.profile-img-wrap img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:1;transition:transform .5s;}
.profile-card:hover .profile-img-wrap img{transform:scale(1.06);}
.profile-overlay{position:absolute;inset:0;background:linear-gradient(180deg,transparent 60%,rgba(0,0,0,.5) 100%);z-index:2;}
.match-badge{position:absolute;top:13px;right:13px;background:linear-gradient(135deg,var(--rose),var(--violet-mid));color:#fff;padding:5px 11px;border-radius:20px;font-size:.73rem;font-weight:700;z-index:3;}
.sign-badge{position:absolute;top:13px;left:13px;background:rgba(0,0,0,.55);backdrop-filter:blur(8px);color:#fff;padding:5px 11px;border-radius:20px;font-size:.78rem;font-weight:600;z-index:3;}
.img-prompt{position:absolute;bottom:9px;left:9px;right:9px;background:rgba(0,0,0,.72);border:1px dashed rgba(255,255,255,.25);color:rgba(255,255,255,.78);font-size:.6rem;padding:4px 9px;border-radius:12px;z-index:4;line-height:1.4;}
.profile-body{padding:18px 20px;}
.profile-name-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.profile-name{font-family:var(--font-display);font-size:1.12rem;font-weight:700;color:var(--text);}
.profile-age{font-size:.84rem;color:var(--text-3);}
.profile-loc{font-size:.8rem;color:var(--text-3);margin-bottom:10px;}
.profile-tags{display:flex;gap:6px;flex-wrap:wrap;}
.ptag{background:var(--surface-2);border:1px solid var(--border);color:var(--text-3);font-size:.7rem;font-weight:500;padding:3px 9px;border-radius:20px;}
.compat-row{margin-top:13px;padding-top:13px;border-top:1px solid var(--border);display:flex;align-items:center;gap:9px;}
.compat-bar{flex:1;height:5px;background:var(--border);border-radius:3px;overflow:hidden;}
.compat-fill{height:100%;background:linear-gradient(90deg,var(--rose),var(--violet-mid));border-radius:3px;}
.compat-pct{font-size:.84rem;font-weight:700;color:var(--rose);}
.match-demo-bg{background:var(--bg-2);}
.match-box{background:var(--card-bg);border:1px solid var(--border);border-radius:28px;padding:44px;max-width:760px;margin:54px auto 0;backdrop-filter:blur(12px);}
.match-profiles-row{display:flex;align-items:center;justify-content:center;gap:26px;margin-bottom:38px;}
.m-profile{text-align:center;flex:1;max-width:170px;}
.m-avatar{width:86px;height:86px;border-radius:50%;overflow:hidden;margin:0 auto 11px;border:3px solid var(--border);background:linear-gradient(135deg,var(--rose),var(--violet-mid));display:flex;align-items:center;justify-content:center;font-size:2rem;box-shadow:0 0 30px rgba(255,77,109,.3);}
.m-avatar img{width:100%;height:100%;object-fit:cover;}
.m-name{font-family:var(--font-display);font-size:.93rem;font-weight:700;color:var(--text);}
.m-sign{font-size:.77rem;color:var(--text-3);margin-top:4px;}
.match-heart{font-size:2.4rem;animation:hbeat 1.4s ease-in-out infinite;}
@keyframes hbeat{0%,100%{transform:scale(1);}50%{transform:scale(1.25);filter:drop-shadow(0 0 12px rgba(255,77,109,.8));}}
.match-scores{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;}
.ms-item{text-align:center;}
.ms-ring{width:70px;height:70px;border-radius:50%;background:var(--surface-2);border:2.5px solid var(--border);display:flex;flex-direction:column;align-items:center;justify-content:center;margin:0 auto 7px;}
.ms-num{font-family:var(--font-display);font-size:1.08rem;font-weight:700;color:var(--rose);}
.ms-type{font-size:.73rem;color:var(--text-2);font-weight:500;}
.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:58px;}
.feat-card{background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius);padding:28px 24px;position:relative;overflow:hidden;transition:var(--transition);backdrop-filter:blur(12px);}
.feat-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--rose),var(--violet-mid));transform:scaleX(0);transform-origin:left;transition:transform .4s;}
.feat-card:hover{transform:translateY(-5px);border-color:rgba(157,78,221,.35);}
.feat-card:hover::after{transform:scaleX(1);}
.feat-emoji{font-size:2rem;margin-bottom:13px;display:block;}
.feat-title{font-family:var(--font-display);font-size:1.08rem;font-weight:700;color:var(--text);margin-bottom:8px;}
.feat-desc{font-size:.84rem;color:var(--text-3);line-height:1.75;}
.testi-bg{background:var(--bg-2);}
.testi-scroll{overflow:hidden;}
.testi-track{display:flex;gap:20px;animation:tscroll 35s linear infinite;}
@keyframes tscroll{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
.testi-scroll:hover .testi-track{animation-play-state:paused;}
.testi-card{background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius);padding:24px;min-width:315px;flex-shrink:0;backdrop-filter:blur(12px);}
.testi-stars{color:var(--gold-soft);font-size:.88rem;letter-spacing:2px;margin-bottom:11px;}
.testi-quote{font-family:var(--font-accent);font-style:italic;font-size:.93rem;color:var(--text-2);line-height:1.85;margin-bottom:16px;font-weight:300;}
.testi-author{display:flex;align-items:center;gap:11px;}
.testi-ava{width:40px;height:40px;border-radius:50%;overflow:hidden;background:linear-gradient(135deg,var(--rose),var(--violet-mid));display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;border:2px solid var(--border);}
.testi-ava img{width:100%;height:100%;object-fit:cover;}
.testi-name{font-weight:600;font-size:.86rem;color:var(--text);line-height:1.2;}
.testi-info{font-size:.74rem;color:var(--text-3);margin-top:2px;}
.testi-sign{margin-left:auto;font-size:1.2rem;}
.events-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:58px;}
.event-card{background:var(--card-bg);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:var(--transition);backdrop-filter:blur(12px);}
.event-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-violet);}
.event-img{height:168px;position:relative;overflow:hidden;background:var(--bg-3);display:flex;align-items:center;justify-content:center;}
.event-img img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .5s;}
.event-card:hover .event-img img{transform:scale(1.07);}
.event-img-ov{position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(0,0,0,.65));z-index:1;}
.event-date-tag{position:absolute;top:11px;right:11px;background:rgba(0,0,0,.55);backdrop-filter:blur(8px);color:#fff;font-size:.72rem;font-weight:700;padding:5px 11px;border-radius:20px;z-index:2;}
.event-emoji{font-size:4rem;z-index:0;}
.event-body{padding:18px 20px;}
.event-type{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--rose);margin-bottom:6px;}
.event-title{font-family:var(--font-display);font-size:1.02rem;font-weight:700;color:var(--text);margin-bottom:7px;line-height:1.3;}
.event-desc{font-size:.81rem;color:var(--text-3);line-height:1.65;}
.event-meta{display:flex;gap:12px;margin-top:11px;font-size:.76rem;color:var(--text-3);flex-wrap:wrap;}
.download-section{background:linear-gradient(135deg,var(--bg-2) 0%,var(--bg-3) 100%);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.download-grid{display:grid;grid-template-columns:1fr 1fr;gap:58px;align-items:center;}
.download-sub{font-family:var(--font-accent);font-style:italic;font-size:1.04rem;color:var(--text-2);line-height:1.9;margin:16px 0 30px;font-weight:300;}
.download-badges{display:flex;gap:13px;flex-wrap:wrap;}
.rating-row{display:flex;align-items:center;gap:9px;margin-top:16px;}
.rating-stars{color:var(--gold-soft);font-size:1rem;letter-spacing:2px;}
.rating-text{font-size:.8rem;color:var(--text-3);}
.phones-wrap{position:relative;height:480px;display:flex;align-items:center;justify-content:center;}
.phone{width:178px;height:356px;background:var(--card-bg);border:1.5px solid var(--border);border-radius:36px;position:absolute;overflow:hidden;box-shadow:0 24px 70px rgba(0,0,0,.45);transition:var(--transition);}
.phone-l{transform:rotate(-9deg) translateX(-100px);z-index:1;}
.phone-c{transform:scale(1.08);z-index:3;}
.phone-r{transform:rotate(9deg) translateX(100px);z-index:1;}
.phone:hover{z-index:10;transform:scale(1.1) !important;}
.phone img{width:100%;height:100%;object-fit:cover;}
.phone-fallback{width:100%;height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px;padding:20px;text-align:center;}
.faq-list{max-width:700px;margin:58px auto 0;}
.faq-item{border-bottom:1px solid var(--border);}
.faq-q{display:flex;align-items:center;justify-content:space-between;padding:19px 0;cursor:pointer;font-family:var(--font-display);font-size:1rem;font-weight:700;color:var(--text);gap:16px;background:none;border:none;width:100%;text-align:left;}
.faq-arrow{font-size:.78rem;color:var(--text-3);transition:transform .3s;flex-shrink:0;}
.faq-item.open .faq-arrow{transform:rotate(180deg);color:var(--rose);}
.faq-a{max-height:0;overflow:hidden;transition:max-height .4s;}
.faq-a-inner{padding-bottom:18px;font-size:.9rem;color:var(--text-2);line-height:1.85;}
.final-cta{text-align:center;background:linear-gradient(180deg,var(--bg-2),var(--bg-3));}
.final-h2{font-family:var(--font-display);font-size:clamp(2rem,5vw,3.8rem);font-weight:900;line-height:1.12;color:var(--text);margin-bottom:16px;}
.final-h2 em{font-style:italic;color:var(--rose);}
@media(max-width:1024px){.steps-grid{grid-template-columns:repeat(2,1fr);}.cosmic-grid{grid-template-columns:1fr;}.zodiac-visual{display:none;}.profiles-grid{grid-template-columns:repeat(2,1fr);}.features-grid{grid-template-columns:repeat(2,1fr);}.download-grid{grid-template-columns:1fr;}.phones-wrap{display:none;}.events-grid{grid-template-columns:repeat(2,1fr);}.match-scores{grid-template-columns:repeat(3,1fr);}}
@media(max-width:768px){.fc{display:none;}.profiles-grid{grid-template-columns:1fr;}.features-grid{grid-template-columns:1fr;}.events-grid{grid-template-columns:1fr;}.steps-grid{grid-template-columns:1fr;}.hero-stats{justify-content:space-around;}.stat-pill{padding:0 16px;}}
@media(max-width:480px){.hero-h1{font-size:2.5rem;letter-spacing:-.5px;}.match-box{padding:22px 16px;}.match-scores{grid-template-columns:repeat(3,1fr);}.ms-ring{width:58px;height:58px;}.ms-num{font-size:.9rem;}}
</style>
</head>
