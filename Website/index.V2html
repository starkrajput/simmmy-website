<!-- HOW IT WORKS -->
<section id="how-it-works" class="section-pad hiw-bg" aria-labelledby="hiw-h">
  <div class="container">
    <div class="reveal" style="text-align:center">
      <span class="section-label">The Journey</span>
      <h2 class="section-title" id="hiw-h">How simmmy <em>Works</em></h2>
      <p class="section-subtitle" style="margin:0 auto">From cosmic blueprint to soulmate — four simple steps.</p>
    </div>
    <div class="steps-grid">
      <article class="step-card reveal reveal-delay-1"><span class="step-num">01</span><div class="step-icon">👤</div><h3>Create Your Profile</h3><p>Share your personality, values, and what you're looking for. Add authentic photos showing the real you.</p></article>
      <article class="step-card reveal reveal-delay-2"><span class="step-num">02</span><div class="step-icon">✨</div><h3>Cosmic Blueprint</h3><p>Enter your birth date, time, and location. We generate your full natal chart, tarot archetype, and numerology life path.</p></article>
      <article class="step-card reveal reveal-delay-3"><span class="step-num">03</span><div class="step-icon">🤖</div><h3>AI Compatibility Scan</h3><p>Our superintelligent engine cross-references 47 compatibility dimensions: astrology, psychology, values, and soul resonance.</p></article>
      <article class="step-card reveal reveal-delay-4"><span class="step-num">04</span><div class="step-icon">💌</div><h3>Meet Your Matches</h3><p>Receive daily curated matches with full cosmic compatibility breakdowns. See exactly why the universe says you belong together.</p></article>
    </div>
  </div>
</section>
<div class="grad-divider"></div>

